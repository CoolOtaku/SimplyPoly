#. Description of the plugin
msgid ""
"A lightweight multilingual plugin for WordPress that manages translations "
"inside a single page using a visual translation builder."
msgstr ""
"Легкий багатомовний плагін для WordPress, який керує перекладами в межах "
"однієї сторінки за допомогою візуального конструктора перекладів."

#: includes/views/admin/admin-page-view.php:29
msgid "Languages for translation"
msgstr "Мови для перекладу"

#: includes/views/admin/admin-page-view.php:39
msgid "Select one or more languages for translation (Ctrl/Command + click)"
msgstr "Виберіть одну або кілька мов для перекладу (Ctrl/Command + клік)"

#: includes/controllers/admin/admin-page-controller.php:30
msgid "Simply Poly Settings"
msgstr "Налаштування Simply Poly"

#: includes/controllers/editor/editor-page-controller.php:39
msgid "Translate"
msgstr "Перекласти"

msgid "Translations saved successfully!"
msgstr "Переклади успішно збережено!"

msgid "Default language"
msgstr "Мова за замовчуванням"

msgid "Main site language"
msgstr "Основна мова сайту"

msgid "Original content is default language (no translation applied)"
msgstr ""
"Оригінальний контент використовується мовою за замовчуванням (переклад не "
"застосовується)"

msgid "Switcher display settings"
msgstr "Налаштування дисплея перемикача"

msgid "Show flags"
msgstr "Показати прапори"

msgid "Show language codes (UA, EN...)"
msgstr "Показати коди мов (UA, EN...)"

msgid "Show language names"
msgstr "Показати назви мов"

msgid "Control how language switcher is displayed"
msgstr "Керування відображенням перемикача мов"

msgid "Dropdown switcher"
msgstr "Випадаючий перемикач"

msgid "Copy"
msgstr "Копіювати"

msgid "Inline switcher"
msgstr "Вбудований перемикач"

msgid ""
"Use dropdown or inline shortcode anywhere on the site to display the "
"language switcher."
msgstr ""
"Використовуйте випадаючий список або вбудований шорткод будь-де на сайті, "
"щоб відобразити перемикач мов."

msgid "Access denied!"
msgstr "Доступ заборонено!"

msgid "No post ID provided!"
msgstr "Ідентифікатор публікації не вказано!"

msgid "Simply Poly Editor"
msgstr "Редактор Simply Poly"

msgid "Preview: Off"
msgstr "Preview: Вимкнено"

msgid "Save"
msgstr "Зберегти"

msgid "Refresh"
msgstr "Оновити"

msgid "Exit"
msgstr "Вихід"
